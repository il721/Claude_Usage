{
  "manifest_version": 3,
  "key": "",
  "name": "Claude Usage Widget Bridge",
  "version": "1.2",
  "description": "Sends Claude.ai rate-limit data to the desktop widget.",
  "permissions": ["alarms", "storage", "nativeMessaging"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
